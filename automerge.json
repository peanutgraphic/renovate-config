{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>peanutgraphic/renovate-config"],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Auto-merge patch + pin + digest updates after status checks pass",
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true
    },
    {
      "description": "Auto-merge dev-dependency minor + patch after status checks pass",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
